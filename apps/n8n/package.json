{
  "name": "@odysea/n8n",
  "version": "1.0.0",
  "private": true,
  "description": "Local n8n workspace for automation, integrated with Docker and Git version control",
  "scripts": {
    "up": "docker compose up --detach",
    "down": "docker compose down",
    "logs": "docker compose logs --follow",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh"
  }
}
