# Unique key for encrypting credentials in n8n's database.
# Change this to a secure, random string (at least 24 characters).
# You can generate a secure key using the following command in your terminal:
# openssl rand -base64 32
N8N_ENCRYPTION_KEY=odysea-local-n8n-encryption-key-change-me-12345

# The email address used as recipient in workflows.
RECIPIENT_EMAIL=your-email@example.com

