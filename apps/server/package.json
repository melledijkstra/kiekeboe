{
  "name": "@odysea/server",
  "version": "0.0.1",
  "description": "Server for the Odysea ecosystem",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "migrate": "tsx scripts/migrate --knexfile ./knexfile.ts migrate:latest"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "knex": "^3.2.10",
    "sqlite3": "^6.0.1",
    "tsx": "^4.22.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6"
  }
}
